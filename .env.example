# Frontend Environment Variables
# Copy this file to .env.local for development
# For production, set these in your hosting platform (Vercel, Netlify, etc.)

# ============================================
# DEVELOPMENT CONFIGURATION
# ============================================

# API Base URL (Backend) - Local Development
VITE_API_URL=http://localhost:8000/api
VITE_WS_URL=ws://localhost:8000/ws

# Google OAuth Client ID
# Get from: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=747022156815-9q3rhol4q46e9livqnefh37ksbt35phd.apps.googleusercontent.com

# ============================================
# PRODUCTION CONFIGURATION (Uncomment & Update)
# ============================================

# Replace with your actual deployed backend URL
# VITE_API_URL=https://your-backend-domain.railway.app/api
# VITE_WS_URL=wss://your-backend-domain.railway.app/ws
# VITE_GOOGLE_CLIENT_ID=

# ============================================
# NOTES:
# ============================================
# 1. For Vercel deployment, add these as Environment Variables in Vercel Dashboard
# 2. Make sure to add your deployed URLs to Google OAuth Authorized Origins
# 3. WebSocket URL should use 'wss://' for HTTPS sites
# 4. Never commit .env.local to git
