# ============================================
# DJANGO CORE SETTINGS
# ============================================
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ============================================
# CORS & CSRF SETTINGS (For Production)
# ============================================
# Uncomment and update for production:
# CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app,http://localhost:5174
# CSRF_TRUSTED_ORIGINS=https://your-backend.railway.app,https://your-frontend.vercel.app

# ============================================
# DATABASE - MONGODB
# ============================================
MONGODB_URI=mongodb://localhost:27017/
MONGODB_DB=alice_exam_proctor

# Production MongoDB Atlas example:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority

# ============================================
# REDIS (For WebSocket/Channels)
# ============================================
REDIS_URL=redis://localhost:6379

# Production Redis example:
# REDIS_URL=redis://red-xxxxx:6379

# ============================================
# EMAIL CONFIGURATION (Gmail SMTP)
# ============================================
# Use Gmail App Password: https://myaccount.google.com/apppasswords
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password-here

# ============================================
# GOOGLE OAUTH 2.0
# ============================================
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# ============================================
# AI CONFIGURATION (Gemini AI)
# ============================================
# Get free API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Alternative: Groq AI (Optional)
# Get from: https://console.groq.com/
# GROQ_API_KEY=your-groq-api-key-here

# ============================================
# IMPORTANT NOTES:
# ============================================
# 1. Never commit this file to git (add to .gitignore)
# 2. For production, set these as environment variables in your hosting platform
# 3. Generate SECRET_KEY: python -c "import secrets; print(secrets.token_hex(50))"
# 4. Set DEBUG=False in production
# 5. Add all your domains to ALLOWED_HOSTS, CORS_ALLOWED_ORIGINS, CSRF_TRUSTED_ORIGINS
